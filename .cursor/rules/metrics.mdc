## Patrones copy-paste

### Worker / Job Processor

```python
import time
from opentelemetry import metrics as otel_metrics

meter = otel_metrics.get_meter("lz")
files_processed = meter.create_counter("lz.files.processed.total", description="Total de archivos procesados", unit="{file}")
processing_duration = meter.create_histogram("lz.file.processing.duration", description="Duración del procesamiento", unit="s")
active_executions = meter.create_up_down_counter("lz.executions.active", description="Ejecuciones activas", unit="{execution}")

def process_file(workspace_id: str, file_type: str, file_id: str):
    base_attrs = {"workspace.id": workspace_id, "file.type": file_type}
    active_executions.add(1, {"workspace.id": workspace_id})
    start = time.monotonic()
    try:
        _do_process(file_id)
        files_processed.add(1, {**base_attrs, "status": "success"})
    except Exception as e:
        files_processed.add(1, {**base_attrs, "status": "failure", "exception.type": type(e).__name__})
        raise
    finally:
        processing_duration.record(time.monotonic() - start, base_attrs)
        active_executions.add(-1, {"workspace.id": workspace_id})
```

### UpDownCounter — atributos idénticos en +1 y -1

```python
active_connections = meter.create_up_down_counter("erp.connections.active", description="Conexiones activas", unit="{connection}")

# CRÍTICO: mismos atributos en ambos add()
attrs = {"workspace.id": workspace_id, "connection.type": connection_type}
active_connections.add(1, attrs)   # acquire
active_connections.add(-1, attrs)  # release
```

### SLO con error budget

```python
executions = meter.create_counter("ur.executions.total", description="Total de ejecuciones", unit="{execution}")

try:
    _do_reconciliation()
    executions.add(1, {"workspace.id": workspace_id, "status": "success"})
except Exception as e:
    executions.add(1, {"workspace.id": workspace_id, "status": "failure", "exception.type": type(e).__name__})
    raise

# SLI en Datadog: sum(ur.executions.total{status:success}) / sum(ur.executions.total)
```

